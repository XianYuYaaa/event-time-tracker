{
  "productName": "时间节点记录系统",
  "version": "1.0.0",
  "identifier": "com.eventtime.tracker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "时间节点记录系统",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1024,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Main capability",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "sql:default",
            "sql:allow-load",
            "sql:allow-execute",
            "sql:allow-select",
            "dialog:default",
            "fs:default",
            "shell:default",
            "shell:allow-open",
            "notification:default",
            "notification:allow-is-permission-granted",
            "notification:allow-request-permission",
            "notification:allow-notify"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "TimeTracker",
    "category": "Productivity",
    "shortDescription": "时间节点记录系统",
    "longDescription": "一个用于记录和管理重要时间节点的应用程序",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
